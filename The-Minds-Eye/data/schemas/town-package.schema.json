{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "town-package.schema.json",
  "title": "The Mind's Eye Town Package Metadata",
  "type": "object",
  "required": ["package_id", "town_name", "state_region", "time_window", "source_manifest", "map_layers", "status"],
  "additionalProperties": false,
  "properties": {
    "package_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "town_name": { "type": "string", "minLength": 1 },
    "state_region": { "type": "string", "minLength": 1 },
    "time_window": {
      "type": "object",
      "required": ["start_year", "end_year", "label"],
      "additionalProperties": false,
      "properties": {
        "start_year": { "type": "integer", "minimum": 1500, "maximum": 2100 },
        "end_year": { "type": "integer", "minimum": 1500, "maximum": 2100 },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "source_manifest": { "type": "string", "minLength": 1 },
    "map_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["map_id", "title", "year", "source_ids"],
        "additionalProperties": false,
        "properties": {
          "map_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "year": { "type": "integer" },
          "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "status": { "type": "string", "enum": ["draft", "pilot", "production"] },
    "notes": { "type": "string" }
  }
}
