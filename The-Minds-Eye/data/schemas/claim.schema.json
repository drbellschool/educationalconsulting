{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim.schema.json",
  "title": "The Mind's Eye Claim and Provenance Records",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["claim_id", "claim_text", "claim_type", "confidence", "source_ids", "reasoning_note", "student_visible", "teacher_visible"],
    "additionalProperties": false,
    "properties": {
      "claim_id": { "type": "string", "pattern": "^claim_[a-z0-9_]+$" },
      "claim_text": { "type": "string", "minLength": 1 },
      "claim_type": { "type": "string", "enum": ["verified_fact", "source_based_inference", "fictional_gameplay"] },
      "confidence": { "type": "string", "enum": ["high", "medium", "low", "fictional"] },
      "source_ids": { "type": "array", "items": { "type": "string" } },
      "related_location_ids": { "type": "array", "items": { "type": "string" } },
      "related_entity_ids": { "type": "array", "items": { "type": "string" } },
      "reasoning_note": { "type": "string", "minLength": 1 },
      "student_visible": { "type": "boolean" },
      "teacher_visible": { "type": "boolean" }
    },
    "allOf": [
      {
        "if": { "properties": { "claim_type": { "const": "verified_fact" } } },
        "then": { "properties": { "source_ids": { "minItems": 1 } } }
      },
      {
        "if": { "properties": { "claim_type": { "const": "source_based_inference" } } },
        "then": { "properties": { "source_ids": { "minItems": 1 } } }
      },
      {
        "if": { "properties": { "claim_type": { "const": "fictional_gameplay" } } },
        "then": { "properties": { "confidence": { "const": "fictional" } } }
      }
    ]
  }
}
