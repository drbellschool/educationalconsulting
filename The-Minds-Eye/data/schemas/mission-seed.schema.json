{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mission-seed.schema.json",
  "title": "The Mind's Eye Mission Seed",
  "type": "object",
  "required": ["mission_id", "town_package_id", "title", "teacher_goal", "location_ids", "claim_ids", "fictional_elements", "student_hook", "teacher_notes"],
  "additionalProperties": false,
  "properties": {
    "mission_id": { "type": "string", "pattern": "^mission_[a-z0-9_]+$" },
    "town_package_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "teacher_goal": { "type": "string", "minLength": 1 },
    "location_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "claim_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "fictional_elements": { "type": "array", "items": { "type": "string" } },
    "student_hook": { "type": "string", "minLength": 1 },
    "teacher_notes": { "type": "string", "minLength": 1 }
  }
}
