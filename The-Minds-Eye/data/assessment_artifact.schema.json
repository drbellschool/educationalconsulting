{
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "session_id",
    "TEKS_ids",
    "assessment_mode",
    "submission_status"
  ],
  "properties": {
    "artifact_id": { "type": "string" },
    "student_id": { "type": "string" },
    "team_id": { "type": "string" },
    "session_id": { "type": "string" },
    "artifact_type": {
      "type": "string",
      "examples": [
        "newspaper_article",
        "editorial",
        "telegram",
        "witness_statement",
        "court_statement",
        "lab_report",
        "engineering_notebook",
        "town_council_proposal"
      ]
    },
    "prompt_context": { "type": "string" },
    "TEKS_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rubric_id": { "type": "string" },
    "assessment_mode": {
      "type": "string",
      "enum": [
        "unscored_practice",
        "ai_feedback_only",
        "formative_evidence",
        "summative_evidence",
        "rubric_scored",
        "teacher_observation_only",
        "mastery_attempt"
      ]
    },
    "submission_text": { "type": "string" },
    "submission_file_url": { "type": "string" },
    "source_ids_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ai_feedback": { "type": "string" },
    "ai_score_recommendation": { "type": "object" },
    "teacher_score": { "type": "object" },
    "teacher_override_note": { "type": "string" },
    "mastery_status": {
      "type": "string",
      "enum": ["not_reviewed", "developing", "successful", "needs_revision", "mastery_met"]
    },
    "submission_status": {
      "type": "string",
      "enum": ["not_started", "draft", "submitted", "returned", "revised", "accepted"]
    },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
